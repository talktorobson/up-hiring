# ============================================================
# Stack: Vercel + Supabase + Clerk + Fly.io
# ============================================================
# Para dev local, usar os valores do docker-compose.yml (Postgres + Redis + LocalStack).
# Para staging/prod, apontar para Supabase, Clerk e Fly.io.

# ----------------------------------------
# Database (Supabase Postgres)
# ----------------------------------------
# DEV LOCAL: usar Postgres do docker-compose
DATABASE_URL=postgresql+asyncpg://ats:ats@localhost:5432/ats
DATABASE_URL_SYNC=postgresql://ats:ats@localhost:5432/ats

# PROD: Supabase São Paulo. Pegar em Settings > Database no dashboard Supabase.
# Modo "Transaction pooler" porta 6543 para o app FastAPI (asyncpg).
# Modo "Session pooler" porta 5432 para Alembic.
# DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
# DATABASE_URL_SYNC=postgresql://postgres.PROJECT_REF:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# ----------------------------------------
# Redis (Upstash em prod, container em dev)
# ----------------------------------------
REDIS_URL=redis://localhost:6379/0
# PROD Upstash: REDIS_URL=rediss://default:SENHA@HOST.upstash.io:6379

# ----------------------------------------
# Auth (Clerk)
# ----------------------------------------
# Pegar em https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ----------------------------------------
# API
# ----------------------------------------
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
# PROD: NEXT_PUBLIC_API_URL=https://api.seu-dominio.com.br

# ----------------------------------------
# Storage (Supabase Storage em prod, LocalStack em dev)
# ----------------------------------------
S3_ENDPOINT=http://localhost:4566
S3_ACCESS_KEY=test
S3_SECRET_KEY=test
S3_BUCKET=up-hiring-dev
S3_REGION=us-east-1

# PROD Supabase Storage S3 compatible (Settings > Storage no dashboard):
# S3_ENDPOINT=https://PROJECT_REF.storage.supabase.co/storage/v1/s3
# S3_ACCESS_KEY=PEGAR_NO_DASHBOARD
# S3_SECRET_KEY=PEGAR_NO_DASHBOARD
# S3_BUCKET=up-hiring-prod
# S3_REGION=sa-east-1

# Service role key do Supabase (uso server side apenas, NUNCA expor no frontend)
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------
# Observability - 1
# ----------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
LOGFIRE_TOKEN=

# ----------------------------------------
# App
# ----------------------------------------
APP_ENV=local
LOG_LEVEL=INFO
